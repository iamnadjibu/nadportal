rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Projects Collection
    match /nad_projects/{projectId} {
      // Public can read and watch
      allow read: if true;
      
      // Only authenticated users (Admins) can modify content nodes
      allow write: if request.auth != null;
      
      // Allow incrementing stats (publicly allowed for telemetry)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views', 'clicks']);
    }
    
    // Comments Collection
    match /nad_comments/{commentId} {
      allow read: if true;
      // Anyone can leave a review
      allow create: if true;
      // Only Admins can purge reviews
      allow delete, update: if request.auth != null;
    }
  }
}
